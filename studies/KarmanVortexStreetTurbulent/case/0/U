FoamFile
{
    version     2.0;
    format      ascii;
    class       volVectorField;
    object      U;
}

dimensions      [0 1 -1 0 0 0 0];

// Initial condition
internalField   uniform (0 0 0);

#include "../constant/parameters"

// Boundary conditions
boundaryField
{
    inlet
    {
        type            fixedValue;
        value           uniform ($U_inlet_x $U_inlet_y 0);
    }
    outlet
    {
        type            zeroGradient; // Free outflow condition, no gradient of velocity at the outlet
    }
    walls
    {
        type            symmetry; // or empty depending on your case
    }
    cylinder
    {
        type            noSlip; // Perfect adhesion 
    }
    front
    {
        type            empty; 
    }
    back
    {
        type            empty; 
    }
}