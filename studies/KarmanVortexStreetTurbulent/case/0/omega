FoamFile
{
    version     2.0;
    format      ascii;
    class       volVectorField;
    object      U;
}
dimensions      [0 0 -1 0 0 0 0];


#include "../constant/parameters"

// initial turbulence frequency, omega = k/(0.09*(U*I)^2)
k_initial = 1.5*pow($U_inlet*$I, 2);
omega_initial = k_initial/(0.09*pow($U_inlet*$I, 2));

internalField   uniform omega_initial;

boundaryField
{
    inlet
    {
        type            fixedValue;
        value           uniform omega_initial;
    }
    outlet
    {
        type            zeroGradient;
    }
    cylinder
    {
        type            omegaWallFunction;
        value           uniform omega_initial;
    }
    walls { type symmetry; }
    front { type empty; }
    back { type empty; }
}