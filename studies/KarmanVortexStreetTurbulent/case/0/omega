FoamFile
{
    version     2.0;
    format      ascii;
    class       volScalarField;
    object      omega;
}
dimensions      [0 0 -1 0 0 0 0];

#include "../constant/parameters"

internalField   uniform $omega_initial;

boundaryField
{
    inlet
    {
        type            fixedValue;
        value           uniform $omega_initial;
    }
    outlet
    {
        type            zeroGradient;
    }
    cylinder
    {
        type            omegaWallFunction;
        value           uniform $omega_initial;
    }
    walls { type symmetry; }
    front { type empty; }
    back { type empty; }
}