FoamFile
{
    version     2.0;
    format      ascii;
    class       volScalarField;
    object      k;
}
dimensions      [0 2 -2 0 0 0 0];

#include "../constant/parameters"

internalField   uniform $k_initial;

boundaryField
{
    inlet
    {
        type            fixedValue;
        value           uniform $k_initial;
    }
    outlet
    {
        type            zeroGradient;
    }
    cylinder
    {
        type            kqRWallFunction;
        value           uniform $k_initial;
    }
    walls { type symmetry; } 
    front { type empty; }
    back { type empty; }
}