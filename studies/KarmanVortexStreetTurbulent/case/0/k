FoamFile
{
    version     2.0;
    format      ascii;
    class       volVectorField;
    object      U;
}
dimensions      [0 2 -2 0 0 0 0];

#include "../constant/parameters"

// initial turbulence kinetic energy, k = 1.5*(U*I)^2
k_initial = 1.5*pow($U_inlet*$I, 2);

internalField   uniform k_initial;

boundaryField
{
    inlet
    {
        type            fixedValue;
        value           uniform k_initial;
    }
    outlet
    {
        type            zeroGradient;
    }
    cylinder
    {
        type            kqRWallFunction;
        value           uniform k_initial;
    }
    walls { type symmetry; } 
    front { type empty; }
    back { type empty; }
}