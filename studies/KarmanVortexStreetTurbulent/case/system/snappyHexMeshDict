/*--------------------------------*- C++ -*----------------------------------*/
FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    object      snappyHexMeshDict;
}

castellatedMesh true;
snap            true;
addLayers       true; // crucial for turbulence

geometry
{
    cylindre.stl
    {
        type triSurfaceMesh;
        name cylinder;
    }

    // near wake box
    nearWake
    {
        type box;
        min (-0.2 -0.3 0.01); // X_min, Y_min, Z_min
        max ( 1.0  0.3  0.099); // X_max, Y_max, Z_max
    }

    // framing all the wake and before
    farWake
    {
        type box;
        min (-0.4 -0.6 0.01); 
        max ( 2.5  0.6  0.099); 
    }
};

castellatedMeshControls
{
    maxLocalCells 800000;
    maxGlobalCells 1000000;
    minRefinementCells 10;
    
    // smoothness through the levels of refinement 
    nCellsBetweenLevels 7; 

    resolveFeatureAngle 30;
    allowFreeStandingZoneFaces true;

    features ( { file "cylindre.eMesh"; level 2; } ); 

    refinementSurfaces
    {
        cylinder 
        { 
            level (5 6); // first for the bulk, second for curved areas
        } 
    }

    refinementRegions
    {
        nearWake
        {
            mode inside;
            levels ((1.0 4)); // very fine mesh in the near wake to capture vortex shedding
        }

        farWake
        {
            mode inside;
            levels ((1.0 2)); // slightly coarser in far wake
        }
    }

    locationInMesh (-0.2 0.2 0.025); 
}

// control of the snapping process (moving the points to the geometry)
snapControls
{
    nSmoothPatch 3;
    tolerance 2.0; 
    nSolveIter 30;
    nRelaxIter 5;
    nFeatureSnapIter 10;
}

// boundary layer meshing parameters
addLayersControls
{
    relativeSizes       true;
    layers
    {
        "cylinder.*"
        {
            nSurfaceLayers 6; // at least 5-6 layers to capture turbulence
        }
    }

    expansionRatio      1.2;    
    finalLayerThickness 0.5;    
    minThickness        0.0001;   
    
    // stability parameters
    nLayerIter          50; 
    nRelaxIter          5;      
    nSmoothSurfaceNormals 1;    
    nSmoothNormals      3;      
    nSmoothThickness    10; 
    nGrow                0;
    minMedialAxisAngle 90;
    maxThicknessToMedialRatio 5;
    nBufferCellsNoExtrude 0;
    
    maxFaceThicknessRatio 0.5;  
    featureAngle        130; // angle for detecting features (corners)     
}

meshQualityControls
{
    maxNonOrtho 65;
    maxBoundarySkewness 20;
    maxInternalSkewness 4;
    maxConcave 80;
    minVol 1e-13;
    minTetQuality 1e-9;
    minArea 1e-13;
    minTwist 0.02;
    minDeterminant 0.001;
    minFaceWeight 0.02;
    minVolRatio 0.01;
    minTriangleTwist 0.02;
    nSmoothScale 4;
    errorReduction 0.75;
    planarity 1e-4;
}

mergeTolerance 1e-6;