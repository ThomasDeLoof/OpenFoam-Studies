FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    object      decomposeParDict;
}

// ================================= Decomposition Method ==============================
// This file is for the decomposition of the domain for parallel processing (for very high calculation costs)

numberOfSubdomains 4; // number of subdomains (processors)

method          simple; // decomposition method (simple, hierarchical, scotch, metis, ...)

simpleCoeffs
{
    n           (2 2 1); // number of subdomains in x, y, z directions (only for simple method)
    delta       0.001;
}