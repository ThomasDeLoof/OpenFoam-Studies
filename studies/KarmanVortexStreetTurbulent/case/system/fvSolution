FoamFile { version 2.0; format ascii; class dictionary; object fvSolution; }

// solver definition for pressure and velocity fields
solvers
{
    p
    {
        solver          GAMG;
        tolerance       1e-06;
        relTol          0.01;
        smoother        GaussSeidel;
    }

    pFinal
    {
        $p;             
        relTol          0;
    }

    "(U|k|omega|.*Final)" 
    {
        solver          smoothSolver;
        smoother        symGaussSeidel;
        tolerance       1e-07;
        relTol          0.1;
    }
}

// PIMPLE (merged PISO-SIMPLE) parameters for transient simulations with larger time steps
PIMPLE
{
    momentumPredictor yes;
    nOuterCorrectors 1;
    nCorrectors 2;
    nNonOrthogonalCorrectors 1;
    pRefCell 0;
    pRefValue 0;
}