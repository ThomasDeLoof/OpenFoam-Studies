FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    location    "constant";
    object      turbulenceProperties;
}

// laminar for Reynolds numbers below ~2000, 'RAS' or 'LES' for higher Reynolds numbers (turbulent flow)
simulationType  RAS; 


// WARNING : remmenber to update U and p files if turbulence is on 
simulationType  RAS;

RAS
{
    RASModel        kOmegaSST;
    turbulence      on;
    printCoeffs     on;
}