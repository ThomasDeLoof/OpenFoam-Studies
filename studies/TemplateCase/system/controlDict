FoamFile { version 2.0; format ascii; class dictionary; object controlDict; }

application     icoFoam;
startFrom       startTime;
startTime       0;
stopAt          endTime;
endTime         1;      // temps de simulation total
deltaT          0.01;    // Pas de temps
writeControl    runTime;
writeInterval   0.1;      // On sauvegarde un résultat tous les 0.1s
purgeWrite      0;
writeFormat     ascii;
writePrecision  6;

functions
{
    velocityProfile
    {
        type            sets;
        libs            ("libpostProcessing.so");
        writeControl    writeTime;
        fields          (U);
        sets
        {
            verticalLine
            {
                type            line;
                axis            y;
                start           (0.5 0 0);
                end             (0.5 1 0);
                nPoints         100;
            }
        }
        format          csv;
    }
}


