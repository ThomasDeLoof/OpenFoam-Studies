FoamFile
{
    version     2.0;
    format      ascii;
    class       volVectorField;
    object      U;
}

dimensions      [0 1 -1 0 0 0 0];

// Initial condition
internalField   uniform (0 0 0);

// Boundary conditions
boundaryField
{
    inlet
    {
        type            fixedValue;
        value           uniform (0.0075 0 0);
    }
    outlet
    {
        type            zeroGradient; // Free outflow condition, no gradient of velocity at the outlet
    }
    walls
    {
        type            noSlip; // Perfect adhesion 
    }
    frontAndBack
    {
        type            empty; // there is no flow in the z direction and the domain is effectively 2D
    }
}