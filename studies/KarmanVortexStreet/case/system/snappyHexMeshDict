/*--------------------------------*- C++ -*----------------------------------*/
FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    object      snappyHexMeshDict;
}

castellatedMesh true;
snap            true;
addLayers       true;

geometry
{
    cylindre.stl 
    {
        type triSurfaceMesh;
        name cylinder; 
    }
    
    refinementBox
    {
        type box;
        min (-0.5 -0.5 -0.1); 
        max (2.5 0.5 0.1); 
    }
};

castellatedMeshControls
{
    maxLocalCells 1000000;
    maxGlobalCells 2000000;
    minRefinementCells 10;
    
    // smoothness through the levels of refinement 
    nCellsBetweenLevels 4; 

    resolveFeatureAngle 30;
    allowFreeStandingZoneFaces true;

    features ( { file "cylindre.eMesh"; level 2; } ); 

    refinementSurfaces
    {
        cylinder 
        { 
            level (3 3); 
        } 
    }

    refinementRegions
    {
        // distance based refinement around the cylinder
        cylinder
        {
            mode distance;
            levels (
                (0.05 3)  // large
                (0.15 2)  // boundary layer
                (0.5 1)   // near wake
            );
        }

        refinementBox
        {
            mode inside;
            levels ((1.0 1));
        }
    }

    locationInMesh (-0.2 0.2 0.025); 
}

snapControls
{
    nSmoothPatch 3;
    tolerance 2.0; 
    nSolveIter 30;
    nRelaxIter 5;
    nFeatureSnapIter 10;
}

addLayersControls
{
    relativeSizes       true;
    layers
    {
        "cylinder.*"
        {
            nSurfaceLayers 3;
        }
    }

    expansionRatio      1.2;    
    finalLayerThickness 0.5;    
    minThickness        0.1;   
    nLayerIter          10; 
    
    nRelaxIter          5;      
    nSmoothSurfaceNormals 1;    
    nSmoothNormals      3;      
    nSmoothThickness    10; 
    nGrow                0;
    minMedialAxisAngle 90;
    maxThicknessToMedialRatio 5;
    nBufferCellsNoExtrude 0;
    
    maxFaceThicknessRatio 0.5;  
    featureAngle        60;     
}

meshQualityControls
{
    maxNonOrtho 65;
    maxBoundarySkewness 20;
    maxInternalSkewness 4;
    maxConcave 80;
    minVol 1e-13;
    minTetQuality 1e-9;
    minArea 1e-13;
    minTwist 0.02;
    minDeterminant 0.001;
    minFaceWeight 0.02;
    minVolRatio 0.01;
    minTriangleTwist 0.02;
    nSmoothScale 4;
    errorReduction 0.75;
    planarity 1e-4;
}

mergeTolerance 1e-6;