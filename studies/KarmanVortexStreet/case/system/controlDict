FoamFile { version 2.0; format ascii; class dictionary; object controlDict; }

application     icoFoam;
startTime       0; // if restarting the simulation
startFrom       latestTime; // latestTime if restarting from a previous run
stopAt          endTime;
endTime         400;      // total simulation time

// time step control
adjustTimeStep  yes;
// maximum stability limit (max CFL number)
// for icofam/pimpleFoam, 0.5 is a safe value, max 1 for Navier-Stokes solvers
maxCo           1;
// maximum time step size (for safety, to avoid too large time steps in case of high velocities)
maxDeltaT       0.8;

// initial time step (OpenFOAM will adjust it immediately after the first step)
deltaT          0.05;

writeControl    runTime;
writeInterval   2;      // time step for saving results