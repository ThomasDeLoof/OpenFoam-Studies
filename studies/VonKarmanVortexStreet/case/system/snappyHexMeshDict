/*--------------------------------*- C++ -*----------------------------------*/
FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    object      snappyHexMeshDict;
}

// choice of base mesh generator
castellatedMesh true;  // mesh cutting (remove cells intersecting geometry)
snap            true;  // mesh snapping to geometry (puts points precisely on the surface)
addLayers       false;  // adding boundary layers (if false, the boundary layer parameters will be ignored)

// geometry and refinement
geometry
{
    cylindre.stl 
    {
        type triSurfaceMesh;
        name cylinder; 
    }
    
    // refinement box definition for the wake region (near the geometry)
    refinementBox
    {
        type box;
        min (-0.5 -0.5 -0.1); // minimum corner of the box 
        max (3.0 0.5 0.1); // maximum corner of the box
    }
};

// mesh generation parameters
castellatedMeshControls
{
    maxLocalCells 1000000;
    maxGlobalCells 2000000;
    minRefinementCells 10;
    nCellsBetweenLevels 3; // minimum number of cells between different refinement levels
    resolveFeatureAngle 30; // angle in degrees for detecting sharp edges
    allowFreeStandingZoneFaces true; // allow faces not attached to any cell, useful for complex geometries

    features ( { file "cylindre.eMesh"; level 1; } ); // using the edge features from the STL file 

    refinementSurfaces
    {
        cylinder { level (1 1); } // detail level, level n means 2^n = 32 times finer than the base mesh 
    }

    refinementRegions
    {
        refinementBox { mode inside; levels ((1 1)); } // refinement level
    }

    // initial point for the meshing algorithm, should be inside the domain but outside the geometry
    locationInMesh (-0.5 0 0.025); 
}

// snapping parameters 
snapControls
{
    nSmoothPatch 3; 
    tolerance 1.0;
    nSolveIter 10;
    nRelaxIter 5;
}

// boundary layer parameters
addLayersControls
{
    relativeSizes true;
    layers
    {
        "cylinder.*" { nSurfaceLayers 3; } // number of layers on the geometry surface
    }
    expansionRatio 1.2;
    finalLayerThickness 0.3;
    minThickness 0.1;
    featureAngle 30;
}

// mesh quality parameters
meshQualityControls
{
    maxNonOrtho 65;
    maxBoundarySkewness 20;
    maxInternalSkewness 4;
    maxConcave 80;
    minVol 1e-13;
    minTetQuality 1e-9; 
    minArea 1e-13;
    minTwist 0.02;
    minDeterminant 0.001;
    minFaceWeight 0.02;
    minVolRatio 0.01;
    minTriangleTwist 0.02;
    nSmoothScale 4;
    errorReduction 0.75;
}

mergeTolerance 1e-6;