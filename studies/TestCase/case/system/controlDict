FoamFile { version 2.0; format ascii; class dictionary; object controlDict; }

application     icoFoam;
startFrom       startTime;
startTime       0;
stopAt          endTime;
endTime         0.5;      // temps de simulation total
deltaT          0.001;    // Pas de temps
writeControl    runTime;
writeInterval   0.01;      // On sauvegarde un résultat tous les 0.1s

functions
{
    velocityProfile
    {
        type            sets;
        libs            ("libpostProcessing.so");
        writeControl    writeTime;
        fields          (U);
        sets
        {
            verticalLine
            {
                type            line;
                axis            y;
                start           (0.5 0 0);
                end             (0.5 1 0);
                nPoints         100;
            }
        }
        format          csv;
    }
}